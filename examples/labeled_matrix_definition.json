{
  "name": "labeled_matrix_flow",
  "description": "Matrix, labels and conditional strategy selection loaded from JSON",
  "slot_definitions": [
    {
      "name": "affinity_matrix",
      "kind": "matrix",
      "representation": "binary",
      "default": [
        [1, 1, 0, 1],
        [0, 1, 1, 0],
        [1, 1, 1, 1],
        [0, 0, 1, 1]
      ],
      "metadata": {
        "row_labels": ["alpha", "beta", "gamma", "delta"],
        "semantic": "binary connectivity matrix"
      }
    },
    {
      "name": "weighted_affinity_matrix",
      "kind": "matrix",
      "representation": "weighted",
      "default": [
        [0.0, 0.82, 0.48, 0.77],
        [0.35, 0.0, 0.91, 0.42],
        [0.88, 0.73, 0.0, 0.95],
        [0.18, 0.51, 0.86, 0.0]
      ],
      "metadata": {
        "row_labels": ["alpha", "beta", "gamma", "delta"],
        "semantic": "weighted attraction matrix"
      }
    },
    {
      "name": "node_labels",
      "kind": "mapping",
      "representation": "tag_map",
      "default": {
        "0": "entry",
        "1": "support",
        "2": "critical",
        "3": "explorer"
      }
    },
    {
      "name": "constructed_solution",
      "kind": "object_collection",
      "representation": "labeled_graph_view",
      "default": []
    },
    {
      "name": "search_mode",
      "kind": "scalar",
      "representation": "strategy_label",
      "default": "unknown"
    },
    {
      "name": "heuristic_score",
      "kind": "scalar",
      "representation": "formula_score",
      "default": 0
    },
    {
      "name": "priority_nodes",
      "kind": "object_collection",
      "representation": "priority_subset",
      "default": []
    },
    {
      "name": "degree_view",
      "kind": "object_collection",
      "representation": "graph_degree_profile",
      "default": []
    },
    {
      "name": "critical_neighbors",
      "kind": "object_collection",
      "representation": "neighbor_subset",
      "default": []
    },
    {
      "name": "connected_components",
      "kind": "object_collection",
      "representation": "component_view",
      "default": []
    },
    {
      "name": "edge_pairs",
      "kind": "object_collection",
      "representation": "edge_pair_view",
      "default": []
    },
    {
      "name": "critical_entry_overlap",
      "kind": "object",
      "representation": "overlap_profile",
      "default": {}
    },
    {
      "name": "critical_reach",
      "kind": "object_collection",
      "representation": "multi_hop_reach",
      "default": []
    },
    {
      "name": "entry_to_explorer_path",
      "kind": "object",
      "representation": "path_profile",
      "default": {}
    },
    {
      "name": "critical_signal_profile",
      "kind": "object_collection",
      "representation": "signal_profile",
      "default": []
    },
    {
      "name": "critical_random_walk",
      "kind": "object",
      "representation": "walk_profile",
      "default": {}
    },
    {
      "name": "entry_flow_profile",
      "kind": "object",
      "representation": "flow_profile",
      "default": {}
    },
    {
      "name": "triangle_patterns",
      "kind": "object_collection",
      "representation": "triangle_pattern",
      "default": []
    },
    {
      "name": "centrality_profile",
      "kind": "object_collection",
      "representation": "centrality_profile",
      "default": []
    },
    {
      "name": "critical_policy_walk",
      "kind": "object",
      "representation": "policy_walk_profile",
      "default": {}
    },
    {
      "name": "closeness_profile",
      "kind": "object_collection",
      "representation": "closeness_profile",
      "default": []
    },
    {
      "name": "square_patterns",
      "kind": "object_collection",
      "representation": "square_pattern",
      "default": []
    },
    {
      "name": "star_patterns",
      "kind": "object_collection",
      "representation": "star_pattern",
      "default": []
    },
    {
      "name": "weighted_band_neighbors",
      "kind": "object_collection",
      "representation": "weighted_neighbor_subset",
      "default": []
    },
    {
      "name": "weighted_degree_view",
      "kind": "object_collection",
      "representation": "weighted_degree_profile",
      "default": []
    },
    {
      "name": "activated_weighted_edges",
      "kind": "object_collection",
      "representation": "activated_edge_pairs",
      "default": []
    },
    {
      "name": "weighted_entry_to_explorer_path",
      "kind": "object",
      "representation": "weighted_path_profile",
      "default": {}
    },
    {
      "name": "weighted_cost_path",
      "kind": "object",
      "representation": "weighted_cost_path_profile",
      "default": {}
    },
    {
      "name": "weighted_edge_strengths",
      "kind": "object_collection",
      "representation": "weighted_edge_strength_profile",
      "default": []
    },
    {
      "name": "weighted_policy_walk",
      "kind": "object",
      "representation": "weighted_policy_walk_profile",
      "default": {}
    },
    {
      "name": "ranked_priority_nodes",
      "kind": "object_collection",
      "representation": "ranked_subset",
      "default": []
    },
    {
      "name": "priority_groups",
      "kind": "mapping",
      "representation": "grouped_subset",
      "default": {}
    },
    {
      "name": "priority_summary",
      "kind": "object",
      "representation": "reduced_summary",
      "default": {}
    },
    {
      "name": "window_profiles",
      "kind": "object_collection",
      "representation": "window_profile",
      "default": []
    },
    {
      "name": "next_strategy",
      "kind": "object",
      "representation": "execution_hint",
      "default": {}
    }
  ],
  "subgraphs": [
    {
      "name": "strategy_block",
      "node": {
        "type": "operator",
        "name": "materialize_strategy_object",
        "operator": "set_slot_value",
        "message": "generic strategy block materialized the next action",
        "snapshot_keys": ["next_strategy"],
        "params": {
          "slot": "next_strategy",
          "value": {
            "phase": {
              "$ref": "args.phase"
            },
            "primary_weight": {
              "$ref": "args.primary_weight"
            },
            "bias": {
              "$ref": "args.bias"
            }
          }
        }
      }
    }
  ],
  "root": {
    "type": "sequence",
    "name": "matrix_driven_metaheuristic",
    "steps": [
      {
        "type": "operator",
        "name": "construct_labeled_solution",
        "operator": "construct_labeled_solution",
        "message": "binary matrix projected into a labeled solution view",
        "snapshot_keys": ["constructed_solution"],
        "params": {
          "matrix": {
            "$ref": "slots.affinity_matrix"
          },
          "labels": {
            "$ref": "slots.node_labels"
          },
          "active_value": 1,
          "output_slot": "constructed_solution"
        }
      },
      {
        "type": "operator",
        "name": "set_degree_view",
        "operator": "set_slot_value",
        "message": "matrix converted into a degree-based neighborhood profile",
        "snapshot_keys": ["degree_view"],
        "params": {
          "slot": "degree_view",
          "value": {
            "$expr": {
              "op": "matrix_degrees",
              "source": {
                "$ref": "slots.affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "active_value": 1
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_critical_neighbors",
        "operator": "set_slot_value",
        "message": "critical node neighborhood extracted from the matrix",
        "snapshot_keys": ["critical_neighbors"],
        "params": {
          "slot": "critical_neighbors",
          "value": {
            "$expr": {
              "op": "neighbors_of",
              "source": {
                "$ref": "slots.affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "node_index": 2,
              "active_value": 1
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_connected_components",
        "operator": "set_slot_value",
        "message": "matrix clustered into connected components",
        "snapshot_keys": ["connected_components"],
        "params": {
          "slot": "connected_components",
          "value": {
            "$expr": {
              "op": "connected_components",
              "source": {
                "$ref": "slots.affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "active_value": 1,
              "undirected": true
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_edge_pairs",
        "operator": "set_slot_value",
        "message": "matrix projected into unique edge pairs",
        "snapshot_keys": ["edge_pairs"],
        "params": {
          "slot": "edge_pairs",
          "value": {
            "$expr": {
              "op": "edge_pairs",
              "source": {
                "$ref": "slots.affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "active_value": 1,
              "directed": false
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_critical_entry_overlap",
        "operator": "set_slot_value",
        "message": "critical and entry neighborhoods compared for overlap",
        "snapshot_keys": ["critical_entry_overlap"],
        "params": {
          "slot": "critical_entry_overlap",
          "value": {
            "$expr": {
              "op": "neighborhood_overlap",
              "source": {
                "$ref": "slots.affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "left_node_index": 2,
              "right_node_index": 0,
              "active_value": 1
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_critical_reach",
        "operator": "set_slot_value",
        "message": "critical node reachability expanded across multiple hops",
        "snapshot_keys": ["critical_reach"],
        "params": {
          "slot": "critical_reach",
          "value": {
            "$expr": {
              "op": "reachable_within",
              "source": {
                "$ref": "slots.affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "start_node_index": 2,
              "max_depth": 2,
              "active_value": 1,
              "undirected": true
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_entry_to_explorer_path",
        "operator": "set_slot_value",
        "message": "entry to explorer shortest path evaluated",
        "snapshot_keys": ["entry_to_explorer_path"],
        "params": {
          "slot": "entry_to_explorer_path",
          "value": {
            "$expr": {
              "op": "shortest_path",
              "source": {
                "$ref": "slots.affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "start_node_index": 0,
              "target_node_index": 3,
              "active_value": 1,
              "undirected": true
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_critical_signal_profile",
        "operator": "set_slot_value",
        "message": "critical signal propagated through the graph",
        "snapshot_keys": ["critical_signal_profile"],
        "params": {
          "slot": "critical_signal_profile",
          "value": {
            "$expr": {
              "op": "propagate_signal",
              "source": {
                "$ref": "slots.affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "seed_nodes": [2],
              "steps": 2,
              "active_value": 1,
              "undirected": true,
              "decay": 0.55,
              "initial_strength": 1.0
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_critical_random_walk",
        "operator": "set_slot_value",
        "message": "critical node random walk profile generated",
        "snapshot_keys": ["critical_random_walk"],
        "params": {
          "slot": "critical_random_walk",
          "value": {
            "$expr": {
              "op": "random_walk",
              "source": {
                "$ref": "slots.affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "start_node_index": 2,
              "steps": 4,
              "active_value": 1,
              "undirected": true,
              "seed": 17
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_entry_flow_profile",
        "operator": "set_slot_value",
        "message": "entry-to-target traffic profile computed from shortest paths",
        "snapshot_keys": ["entry_flow_profile"],
        "params": {
          "slot": "entry_flow_profile",
          "value": {
            "$expr": {
              "op": "flow_profile",
              "source": {
                "$ref": "slots.affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "source_nodes": [0],
              "target_nodes": [2, 3],
              "active_value": 1,
              "undirected": true
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_triangle_patterns",
        "operator": "set_slot_value",
        "message": "triangle motifs detected in the graph",
        "snapshot_keys": ["triangle_patterns"],
        "params": {
          "slot": "triangle_patterns",
          "value": {
            "$expr": {
              "op": "triangle_patterns",
              "source": {
                "$ref": "slots.affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "active_value": 1
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_centrality_profile",
        "operator": "set_slot_value",
        "message": "graph centrality profile computed",
        "snapshot_keys": ["centrality_profile"],
        "params": {
          "slot": "centrality_profile",
          "value": {
            "$expr": {
              "op": "centrality_profile",
              "source": {
                "$ref": "slots.affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "active_value": 1,
              "undirected": true
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_closeness_profile",
        "operator": "set_slot_value",
        "message": "graph closeness profile computed",
        "snapshot_keys": ["closeness_profile"],
        "params": {
          "slot": "closeness_profile",
          "value": {
            "$expr": {
              "op": "closeness_profile",
              "source": {
                "$ref": "slots.affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "active_value": 1,
              "undirected": true
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_critical_policy_walk",
        "operator": "set_slot_value",
        "message": "critical node policy-guided walk generated",
        "snapshot_keys": ["critical_policy_walk"],
        "params": {
          "slot": "critical_policy_walk",
          "value": {
            "$expr": {
              "op": "policy_walk",
              "source": {
                "$ref": "slots.affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "start_node_index": 2,
              "steps": 4,
              "active_value": 1,
              "undirected": true,
              "policy": "prefer_central"
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_square_patterns",
        "operator": "set_slot_value",
        "message": "square-like motifs detected in the graph",
        "snapshot_keys": ["square_patterns"],
        "params": {
          "slot": "square_patterns",
          "value": {
            "$expr": {
              "op": "square_patterns",
              "source": {
                "$ref": "slots.affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "active_value": 1
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_star_patterns",
        "operator": "set_slot_value",
        "message": "star-like motifs detected in the graph",
        "snapshot_keys": ["star_patterns"],
        "params": {
          "slot": "star_patterns",
          "value": {
            "$expr": {
              "op": "star_patterns",
              "source": {
                "$ref": "slots.affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "active_value": 1,
              "undirected": true,
              "min_degree": 3,
              "max_leaf_degree": 3
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_weighted_band_neighbors",
        "operator": "set_slot_value",
        "message": "weighted matrix filtered with a band activation rule",
        "snapshot_keys": ["weighted_band_neighbors"],
        "params": {
          "slot": "weighted_band_neighbors",
          "value": {
            "$expr": {
              "op": "neighbors_of",
              "source": {
                "$ref": "slots.weighted_affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "node_index": 2,
              "activation": {
                "mode": "between",
                "min_value": 0.7,
                "max_value": 0.9
              }
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_weighted_degree_view",
        "operator": "set_slot_value",
        "message": "weighted matrix projected into a thresholded degree view",
        "snapshot_keys": ["weighted_degree_view"],
        "params": {
          "slot": "weighted_degree_view",
          "value": {
            "$expr": {
              "op": "matrix_degrees",
              "source": {
                "$ref": "slots.weighted_affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "activation": {
                "mode": "gte",
                "value": 0.75
              }
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_activated_weighted_edges",
        "operator": "set_slot_value",
        "message": "weighted edges activated by threshold and collapsed into unique pairs",
        "snapshot_keys": ["activated_weighted_edges"],
        "params": {
          "slot": "activated_weighted_edges",
          "value": {
            "$expr": {
              "op": "edge_pairs",
              "source": {
                "$ref": "slots.weighted_affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "activation": {
                "mode": "gte",
                "value": 0.75
              },
              "directed": false
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_weighted_entry_to_explorer_path",
        "operator": "set_slot_value",
        "message": "weighted graph path resolved through strong-edge activation",
        "snapshot_keys": ["weighted_entry_to_explorer_path"],
        "params": {
          "slot": "weighted_entry_to_explorer_path",
          "value": {
            "$expr": {
              "op": "shortest_path",
              "source": {
                "$ref": "slots.weighted_affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "start_node_index": 0,
              "target_node_index": 3,
              "activation": {
                "mode": "gte",
                "value": 0.85
              },
              "undirected": true
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_weighted_cost_path",
        "operator": "set_slot_value",
        "message": "weighted graph path resolved with edge costs instead of hop count",
        "snapshot_keys": ["weighted_cost_path"],
        "params": {
          "slot": "weighted_cost_path",
          "value": {
            "$expr": {
              "op": "weighted_shortest_path",
              "source": {
                "$ref": "slots.weighted_affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "start_node_index": 0,
              "target_node_index": 3,
              "activation": {
                "mode": "nonzero"
              },
              "undirected": true,
              "cost_mode": "inverse_weight",
              "cost_power": 1.0
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_weighted_edge_strengths",
        "operator": "set_slot_value",
        "message": "weighted edges ranked by strength",
        "snapshot_keys": ["weighted_edge_strengths"],
        "params": {
          "slot": "weighted_edge_strengths",
          "value": {
            "$expr": {
              "op": "edge_strength_profile",
              "source": {
                "$ref": "slots.weighted_affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "activation": {
                "mode": "nonzero"
              },
              "directed": false
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_weighted_policy_walk",
        "operator": "set_slot_value",
        "message": "weighted walk advanced with edge-aware policy",
        "snapshot_keys": ["weighted_policy_walk"],
        "params": {
          "slot": "weighted_policy_walk",
          "value": {
            "$expr": {
              "op": "weighted_policy_walk",
              "source": {
                "$ref": "slots.weighted_affinity_matrix"
              },
              "labels": {
                "$ref": "slots.node_labels"
              },
              "start_node_index": 0,
              "steps": 4,
              "activation": {
                "mode": "nonzero"
              },
              "undirected": true,
              "policy": "prefer_unvisited_strong",
              "cost_mode": "inverse_weight"
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_priority_nodes",
        "operator": "set_slot_value",
        "message": "priority subset derived with filter and map transforms",
        "snapshot_keys": ["priority_nodes"],
        "params": {
          "slot": "priority_nodes",
          "value": {
            "$expr": {
              "op": "map",
              "source": {
                "op": "filter",
                "source": {
                  "$ref": "slots.constructed_solution"
                },
                "as": "item",
                "where": {
                  "op": "gte",
                  "left": {
                    "op": "ref",
                    "path": "vars.item.connection_count"
                  },
                  "right": 2
                }
              },
              "as": "item",
              "value": {
                "node_id": {
                  "op": "ref",
                  "path": "vars.item.node_id"
                },
                "label": {
                  "op": "ref",
                  "path": "vars.item.label"
                },
                "strength": {
                  "op": "mul",
                  "args": [
                    {
                      "op": "ref",
                      "path": "vars.item.connection_count"
                    },
                    1.1
                  ]
                }
              }
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_priority_groups",
        "operator": "set_slot_value",
        "message": "priority nodes grouped by label",
        "snapshot_keys": ["priority_groups"],
        "params": {
          "slot": "priority_groups",
          "value": {
            "$expr": {
              "op": "group_by",
              "source": {
                "$ref": "slots.priority_nodes"
              },
              "as": "item",
              "key": {
                "op": "ref",
                "path": "vars.item.label"
              }
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_ranked_priority_nodes",
        "operator": "set_slot_value",
        "message": "priority nodes ranked by strength",
        "snapshot_keys": ["ranked_priority_nodes"],
        "params": {
          "slot": "ranked_priority_nodes",
          "value": {
            "$expr": {
              "op": "sort_by",
              "source": {
                "$ref": "slots.priority_nodes"
              },
              "as": "item",
              "key": {
                "op": "ref",
                "path": "vars.item.strength"
              },
              "descending": true
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_priority_summary",
        "operator": "set_slot_value",
        "message": "priority nodes reduced into a summary object",
        "snapshot_keys": ["priority_summary"],
        "params": {
          "slot": "priority_summary",
          "value": {
            "$expr": {
              "op": "reduce",
              "source": {
                "$ref": "slots.priority_nodes"
              },
              "as": "item",
              "accumulator_as": "acc",
              "initial": {
                "total_strength": 0,
                "critical_count": 0,
                "total_nodes": 0,
                "avg_strength": 0
              },
              "value": {
                "total_strength": {
                  "op": "add",
                  "args": [
                    {
                      "op": "ref",
                      "path": "vars.acc.total_strength"
                    },
                    {
                      "op": "ref",
                      "path": "vars.item.strength"
                    }
                  ]
                },
                "critical_count": {
                  "op": "add",
                  "args": [
                    {
                      "op": "ref",
                      "path": "vars.acc.critical_count"
                    },
                    {
                      "op": "if",
                      "condition": {
                        "op": "eq",
                        "left": {
                          "op": "ref",
                          "path": "vars.item.label"
                        },
                        "right": "critical"
                      },
                      "then": 1,
                      "else": 0
                    }
                  ]
                },
                "total_nodes": {
                  "op": "add",
                  "args": [
                    {
                      "op": "ref",
                      "path": "vars.acc.total_nodes"
                    },
                    1
                  ]
                },
                "avg_strength": {
                  "op": "div",
                  "left": {
                    "op": "add",
                    "args": [
                      {
                        "op": "ref",
                        "path": "vars.acc.total_strength"
                      },
                      {
                        "op": "ref",
                        "path": "vars.item.strength"
                      }
                    ]
                  },
                  "right": {
                    "op": "add",
                    "args": [
                      {
                        "op": "ref",
                        "path": "vars.acc.total_nodes"
                      },
                      1
                    ]
                  }
                }
              }
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_window_profiles",
        "operator": "set_slot_value",
        "message": "ranked nodes evaluated through sliding windows",
        "snapshot_keys": ["window_profiles"],
        "params": {
          "slot": "window_profiles",
          "value": {
            "$expr": {
              "op": "sliding_window",
              "source": {
                "$ref": "slots.ranked_priority_nodes"
              },
              "size": 2,
              "as": "window",
              "value": {
                "labels": {
                  "op": "map",
                  "source": {
                    "op": "ref",
                    "path": "vars.window"
                  },
                  "as": "item",
                  "value": {
                    "op": "ref",
                    "path": "vars.item.label"
                  }
                },
                "combined_strength": {
                  "op": "sum",
                  "source": {
                    "op": "ref",
                    "path": "vars.window"
                  },
                  "as": "item",
                  "value": {
                    "op": "ref",
                    "path": "vars.item.strength"
                  }
                }
              }
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_heuristic_score",
        "operator": "set_slot_value",
        "message": "heuristic score computed from a mathematical formula",
        "snapshot_keys": ["heuristic_score", "degree_view", "critical_neighbors", "connected_components", "edge_pairs", "critical_entry_overlap", "critical_reach", "entry_to_explorer_path", "critical_signal_profile", "critical_random_walk", "entry_flow_profile", "triangle_patterns", "centrality_profile", "closeness_profile", "critical_policy_walk", "square_patterns", "star_patterns", "weighted_band_neighbors", "weighted_degree_view", "activated_weighted_edges", "weighted_entry_to_explorer_path", "weighted_cost_path", "weighted_edge_strengths", "weighted_policy_walk", "priority_nodes", "ranked_priority_nodes", "priority_summary", "window_profiles"],
        "params": {
          "slot": "heuristic_score",
          "value": {
            "$expr": {
              "op": "round",
              "value": {
                "op": "add",
                "args": [
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "ref",
                        "path": "metrics.dense_rows"
                      },
                      1.35
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "ref",
                        "path": "slots.priority_summary.critical_count"
                      },
                      2.4
                    ]
                  },
                  {
                    "op": "ref",
                    "path": "slots.priority_summary.avg_strength"
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "reduce",
                        "source": {
                          "$ref": "slots.connected_components"
                        },
                        "as": "item",
                        "accumulator_as": "acc",
                        "initial": 0,
                        "value": {
                          "op": "if",
                          "condition": {
                            "op": "gt",
                            "left": {
                              "op": "ref",
                              "path": "vars.item.size"
                            },
                            "right": {
                              "op": "ref",
                              "path": "vars.acc"
                            }
                          },
                          "then": {
                            "op": "ref",
                            "path": "vars.item.size"
                          },
                          "else": {
                            "op": "ref",
                            "path": "vars.acc"
                          }
                        }
                      },
                      0.5
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "ref",
                        "path": "slots.closeness_profile.0.score"
                      },
                      0.85
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "len",
                        "value": {
                          "$ref": "slots.square_patterns"
                        }
                      },
                      0.65
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "ref",
                        "path": "slots.centrality_profile.0.score"
                      },
                      0.75
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "ref",
                        "path": "slots.critical_policy_walk.unique_visits"
                      },
                      0.35
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "len",
                        "value": {
                          "$ref": "slots.star_patterns"
                        }
                      },
                      0.5
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "len",
                        "value": {
                          "$ref": "slots.critical_neighbors"
                        }
                      },
                      0.8
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "ref",
                        "path": "slots.critical_entry_overlap.overlap_count"
                      },
                      0.7
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "len",
                        "value": {
                          "$ref": "slots.critical_reach"
                        }
                      },
                      0.4
                    ]
                  },
                  {
                    "op": "if",
                    "condition": {
                      "op": "ref",
                      "path": "slots.entry_to_explorer_path.reachable"
                    },
                    "then": 1.2,
                    "else": 0
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "sum",
                        "source": {
                          "$ref": "slots.critical_signal_profile"
                        },
                        "as": "item",
                        "value": {
                          "op": "ref",
                          "path": "vars.item.score"
                        }
                      },
                      0.3
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "len",
                        "value": {
                          "$ref": "slots.critical_random_walk.trace"
                        }
                      },
                      0.25
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "ref",
                        "path": "slots.entry_flow_profile.successful_path_count"
                      },
                      0.6
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "len",
                        "value": {
                          "$ref": "slots.triangle_patterns"
                        }
                      },
                      0.9
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "len",
                        "value": {
                          "$ref": "slots.activated_weighted_edges"
                        }
                      },
                      0.35
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "ref",
                        "path": "slots.weighted_degree_view.2.total_edge_weight"
                      },
                      0.4
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "sum",
                        "source": {
                          "$ref": "slots.weighted_band_neighbors"
                        },
                        "as": "item",
                        "value": {
                          "op": "ref",
                          "path": "vars.item.edge_value"
                        }
                      },
                      0.25
                    ]
                  },
                  {
                    "op": "if",
                    "condition": {
                      "op": "ref",
                      "path": "slots.weighted_entry_to_explorer_path.reachable"
                    },
                    "then": 0.95,
                    "else": 0
                  },
                  {
                    "op": "if",
                    "condition": {
                      "op": "ref",
                      "path": "slots.weighted_cost_path.reachable"
                    },
                    "then": {
                      "op": "div",
                      "left": 1.4,
                      "right": {
                        "op": "ref",
                        "path": "slots.weighted_cost_path.total_cost"
                      }
                    },
                    "else": 0
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "ref",
                        "path": "slots.weighted_edge_strengths.0.strength"
                      },
                      0.45
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "ref",
                        "path": "slots.weighted_policy_walk.unique_visits"
                      },
                      0.3
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "sum",
                        "source": {
                          "$ref": "slots.weighted_policy_walk.traversed_weights"
                        },
                        "as": "item",
                        "value": {
                          "op": "ref",
                          "path": "vars.item"
                        }
                      },
                      0.18
                    ]
                  },
                  {
                    "op": "if",
                    "condition": {
                      "op": "gt",
                      "left": {
                        "op": "len",
                        "value": {
                          "$ref": "slots.window_profiles"
                        }
                      },
                      "right": 0
                    },
                    "then": {
                      "op": "div",
                      "left": {
                        "op": "sum",
                        "source": {
                          "$ref": "slots.window_profiles"
                        },
                        "as": "item",
                        "value": {
                          "op": "ref",
                          "path": "vars.item.combined_strength"
                        }
                      },
                      "right": {
                        "op": "len",
                        "value": {
                          "$ref": "slots.window_profiles"
                        }
                      }
                    },
                    "else": 0
                  }
                ]
              },
              "digits": 3
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_search_mode",
        "operator": "set_slot_value",
        "message": "strategy mode derived from expression rules",
        "snapshot_keys": ["search_mode", "heuristic_score"],
        "params": {
          "slot": "search_mode",
          "value": {
            "$expr": {
              "op": "if",
              "condition": {
                "op": "gte",
                "left": {
                  "op": "ref",
                  "path": "slots.heuristic_score"
                },
                "right": 7.0
              },
              "then": "intensify",
              "else": "diversify"
            }
          }
        }
      },
      {
        "type": "condition",
        "name": "select_strategy_branch",
        "true_message": "intensification branch selected",
        "false_message": "diversification branch selected",
        "snapshot_keys": ["search_mode", "heuristic_score", "next_strategy"],
        "condition": {
          "expression": {
            "op": "eq",
            "left": {
              "op": "ref",
              "path": "slots.search_mode"
            },
            "right": "intensify"
          }
        },
        "then": {
          "type": "subgraph",
          "name": "run_strategy_block_for_intensify",
          "ref": "strategy_block",
          "message": "generic strategy block invoked with intensify parameters",
          "snapshot_keys": ["next_strategy"],
          "params": {
            "phase": "intensify",
            "primary_weight": 0.9,
            "bias": "very_high"
          }
        },
        "else": {
          "type": "subgraph",
          "name": "run_strategy_block_for_diversify",
          "ref": "strategy_block",
          "message": "generic strategy block invoked with diversify parameters",
          "snapshot_keys": ["next_strategy"],
          "params": {
            "phase": "diversify",
            "primary_weight": 0.6,
            "bias": "medium"
          }
        }
      }
    ]
  }
}
