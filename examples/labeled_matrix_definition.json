{
  "name": "labeled_matrix_flow",
  "description": "Matrix, labels and conditional strategy selection loaded from JSON",
  "slot_definitions": [
    {
      "name": "affinity_matrix",
      "kind": "matrix",
      "representation": "binary",
      "default": [
        [1, 1, 0, 1],
        [0, 1, 1, 0],
        [1, 1, 1, 1],
        [0, 0, 1, 1]
      ],
      "metadata": {
        "row_labels": ["alpha", "beta", "gamma", "delta"],
        "semantic": "binary connectivity matrix"
      }
    },
    {
      "name": "node_labels",
      "kind": "mapping",
      "representation": "tag_map",
      "default": {
        "0": "entry",
        "1": "support",
        "2": "critical",
        "3": "explorer"
      }
    },
    {
      "name": "constructed_solution",
      "kind": "object_collection",
      "representation": "labeled_graph_view",
      "default": []
    },
    {
      "name": "search_mode",
      "kind": "scalar",
      "representation": "strategy_label",
      "default": "unknown"
    },
    {
      "name": "heuristic_score",
      "kind": "scalar",
      "representation": "formula_score",
      "default": 0
    },
    {
      "name": "next_strategy",
      "kind": "object",
      "representation": "execution_hint",
      "default": {}
    }
  ],
  "subgraphs": [
    {
      "name": "intensify_strategy_block",
      "node": {
        "type": "operator",
        "name": "apply_intensify_strategy",
        "operator": "apply_intensify_strategy",
        "message": "intensive follow-up heuristic prepared",
        "snapshot_keys": ["next_strategy"],
        "params": {
          "local_search_weight": 0.9,
          "merge_bias": "very_high",
          "output_slot": "next_strategy"
        }
      }
    },
    {
      "name": "diversify_strategy_block",
      "node": {
        "type": "operator",
        "name": "apply_diversify_strategy",
        "operator": "apply_diversify_strategy",
        "message": "diversification follow-up heuristic prepared",
        "snapshot_keys": ["next_strategy"],
        "params": {
          "shake_strength": 0.6,
          "restart_bias": "medium",
          "output_slot": "next_strategy"
        }
      }
    }
  ],
  "root": {
    "type": "sequence",
    "name": "matrix_driven_metaheuristic",
    "steps": [
      {
        "type": "operator",
        "name": "construct_labeled_solution",
        "operator": "construct_labeled_solution",
        "message": "binary matrix projected into a labeled solution view",
        "snapshot_keys": ["constructed_solution"],
        "params": {
          "matrix": {
            "$ref": "slots.affinity_matrix"
          },
          "labels": {
            "$ref": "slots.node_labels"
          },
          "active_value": 1,
          "output_slot": "constructed_solution"
        }
      },
      {
        "type": "operator",
        "name": "set_heuristic_score",
        "operator": "set_slot_value",
        "message": "heuristic score computed from a mathematical formula",
        "snapshot_keys": ["heuristic_score"],
        "params": {
          "slot": "heuristic_score",
          "value": {
            "$expr": {
              "op": "round",
              "value": {
                "op": "add",
                "args": [
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "ref",
                        "path": "metrics.dense_rows"
                      },
                      1.35
                    ]
                  },
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "count",
                        "source": {
                          "$ref": "slots.constructed_solution"
                        },
                        "as": "item",
                        "where": {
                          "op": "and",
                          "args": [
                            {
                              "op": "eq",
                              "left": {
                                "op": "ref",
                                "path": "vars.item.label"
                              },
                              "right": "critical"
                            },
                            {
                              "op": "gte",
                              "left": {
                                "op": "ref",
                                "path": "vars.item.connection_count"
                              },
                              "right": 3
                            }
                          ]
                        }
                      },
                      2.4
                    ]
                  },
                  {
                    "op": "div",
                    "left": {
                      "op": "sum",
                      "source": {
                        "$ref": "slots.constructed_solution"
                      },
                      "as": "item",
                      "value": {
                        "op": "ref",
                        "path": "vars.item.connection_count"
                      }
                    },
                    "right": {
                      "op": "len",
                      "value": {
                        "$ref": "slots.constructed_solution"
                      }
                    }
                  }
                ]
              },
              "digits": 3
            }
          }
        }
      },
      {
        "type": "operator",
        "name": "set_search_mode",
        "operator": "set_slot_value",
        "message": "strategy mode derived from expression rules",
        "snapshot_keys": ["search_mode", "heuristic_score"],
        "params": {
          "slot": "search_mode",
          "value": {
            "$expr": {
              "op": "if",
              "condition": {
                "op": "gte",
                "left": {
                  "op": "ref",
                  "path": "slots.heuristic_score"
                },
                "right": 7.0
              },
              "then": "intensify",
              "else": "diversify"
            }
          }
        }
      },
      {
        "type": "condition",
        "name": "select_strategy_branch",
        "true_message": "intensification branch selected",
        "false_message": "diversification branch selected",
        "snapshot_keys": ["search_mode", "heuristic_score", "next_strategy"],
        "condition": {
          "expression": {
            "op": "eq",
            "left": {
              "op": "ref",
              "path": "slots.search_mode"
            },
            "right": "intensify"
          }
        },
        "then": {
          "type": "subgraph",
          "name": "run_intensify_strategy_block",
          "ref": "intensify_strategy_block",
          "message": "reusable intensify block invoked",
          "snapshot_keys": ["next_strategy"]
        },
        "else": {
          "type": "subgraph",
          "name": "run_diversify_strategy_block",
          "ref": "diversify_strategy_block",
          "message": "reusable diversify block invoked",
          "snapshot_keys": ["next_strategy"]
        }
      }
    ]
  }
}
